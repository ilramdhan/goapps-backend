{{define "content"}}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
  <!-- Description -->
  <tr>
    <td style="padding-bottom:24px;">
      <p style="margin:0; font-size:14px; color:#5c5f61; font-family:Arial,Helvetica,sans-serif; line-height:1.6;">
        Hi{{if .RecipientName}} <strong style="color:#111c2d;">{{.RecipientName}}</strong>{{end}},<br>
        Your <strong style="color:#111c2d;">{{.AppName}}</strong> account has been created. You can now sign in and start working.
      </p>
    </td>
  </tr>
  <!-- Account info -->
  <tr>
    <td style="padding-bottom:24px;">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" bgcolor="#eff6ff" style="border:1px solid #dbeafe; border-radius:8px;">
        <tr>
          <td style="padding:16px 20px;">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td width="100" valign="top" style="font-size:12px; font-weight:600; color:#5c5f61; text-transform:uppercase; letter-spacing:0.05em; font-family:Arial,Helvetica,sans-serif;">Email</td>
                <td style="font-size:13px; color:#111c2d; font-family:Arial,Helvetica,sans-serif;">{{.RecipientEmail}}</td>
              </tr>
            </table>
          </td>
        </tr>
      </table>
    </td>
  </tr>
  <!-- CTA -->
  <tr>
    <td align="center" style="padding-bottom:8px;">
      <a href="{{.LoginURL}}" style="display:inline-block; padding:12px 32px; background-color:#3b82f6; color:#ffffff; font-size:14px; font-weight:600; text-decoration:none; border-radius:6px; font-family:Arial,Helvetica,sans-serif; letter-spacing:0.02em;">Sign In to {{.AppName}}</a>
    </td>
  </tr>
</table>
{{end}}
